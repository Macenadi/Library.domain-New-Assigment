@model Library.domain.Models.Member

@{
    ViewData["Title"] = "Delete Member";
}

<div class="card card-soft border-danger">
    <div class="card-body">
        <h1 class="page-title text-danger">Delete Member</h1>
        <p class="mb-4">Are you sure you want to delete this member?</p>

        <dl class="row mb-4">
            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Phone</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
