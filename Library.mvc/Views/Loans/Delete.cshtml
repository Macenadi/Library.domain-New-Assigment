@model Library.domain.Models.Loan

@{
    ViewData["Title"] = "Delete Loan";
}

<div class="card card-soft border-danger">
    <div class="card-body">
        <h1 class="page-title text-danger">Delete Loan</h1>
        <p class="mb-4">Are you sure you want to delete this loan?</p>

        <dl class="row mb-4">
            <dt class="col-sm-3">Book</dt>
            <dd class="col-sm-9">@Model.Book?.Title</dd>

            <dt class="col-sm-3">Member</dt>
            <dd class="col-sm-9">@Model.Member?.FullName</dd>

            <dt class="col-sm-3">Loan Date</dt>
            <dd class="col-sm-9">@Model.LoanDate.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>