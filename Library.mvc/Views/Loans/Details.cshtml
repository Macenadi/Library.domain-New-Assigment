@model Library.domain.Models.Loan

@{
    ViewData["Title"] = "Loan Details";
    var isOverdue = Model.ReturnedDate == null && Model.DueDate < DateTime.Now;
    var isReturned = Model.ReturnedDate != null;
}

<div class="card card-soft">
    <div class="card-body">
        <h1 class="page-title">Loan Details</h1>
        <hr />

        <dl class="row mb-4">
            <dt class="col-sm-3">Book</dt>
            <dd class="col-sm-9">@Model.Book?.Title</dd>

            <dt class="col-sm-3">Member</dt>
            <dd class="col-sm-9">@Model.Member?.FullName</dd>

            <dt class="col-sm-3">Loan Date</dt>
            <dd class="col-sm-9">@Model.LoanDate.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Returned Date</dt>
            <dd class="col-sm-9">@(Model.ReturnedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (isReturned)
                {
                    <span class="badge bg-success">Returned</span>
                }
                else if (isOverdue)
                {
                    <span class="badge bg-danger">Overdue</span>
                }
                else
                {
                    <span class="badge bg-primary">Active</span>
                }
            </dd>
        </dl>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </div>
</div>